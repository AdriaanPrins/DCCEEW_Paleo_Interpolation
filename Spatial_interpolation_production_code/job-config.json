{
  "taskGroups": [
    {
      "taskSpec": {
        "runnables": [
          {
            "container": {
              "imageUri": "australia-southeast2-docker.pkg.dev/paleo-interpolation/paleo-repo/paleo-geotiff:latest"
            }
          }
        ],
        "computeResource": {
          "cpuMilli": 16000, 
          "memoryMib": 60000 
        },
        "maxRunDuration": "14400s" 
      },
      "taskCount": 1000, 
      "parallelism": 46 
    }
  ],
  "allocationPolicy": {
    "instances": [
      {
        "policy": {
          "machineType": "n2-standard-16"
        }
      }
    ]
  },
  "logsPolicy": {
    "destination": "CLOUD_LOGGING"
  }
}